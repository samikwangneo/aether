# ── AI Keys ────────────────────────────────────────────────────────────────────
# Gemini: builds context docs for TerpAI + fallback AI when TerpAI is down
GEMINI_API_KEY=your_key_here

# ElevenLabs: text-to-speech for voice features (Person 4)
ELEVENLABS_API_KEY=your_key_here

# ── TerpAI API ─────────────────────────────────────────────────────────────────
# Name of the agent we create/reuse in TerpAI
TERPAI_AGENT_NAME=Aether Study Assistant

# Agent chat URL (get from TerpAI UI — click your agent, copy the URL)
# Format: https://terpai.umd.edu/chat/<conversation-segment-id>
TERPAI_AGENT_URL=

# Bearer JWT token for TerpAI API
# How to get: open TerpAI in Chrome → F12 → Network tab → send any message →
# copy the Authorization: Bearer ... value from any request to terpai.umd.edu
# Valid for ~30 minutes. Paste a fresh one before each demo session.
TERPAI_TOKEN=
